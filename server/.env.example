# Server
PORT=5000
NODE_ENV=development

# PostgreSQL (Docker)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=eresumeier
DB_USER=eresumeier_user
DB_PASSWORD=eresumeier_pass

# Redis (Docker)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=eresumeier_jwt_secret_key_2026
JWT_EXPIRES_IN=7d

# LLM API (Google Gemini - get key from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Email (Gmail SMTP for shortlist notifications)
EMAIL_USER=your.gmail@gmail.com
EMAIL_PASS=your-16-char-app-password
